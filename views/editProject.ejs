<!DOCTYPE html>
<html lang="en" data-theme="luxury">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Add project</title>
        <link rel="stylesheet" href="/css/main.css" />
    </head>
    <body>

        <!-- Navbar -->
        <%- include('partials/navbar') %>
        
        <div class="page-container">

            <!-- Header -->
            <div class="standard-hero pb-2">
              <div class="hero-content text-center ">
                <div class="max-w-md">
                  <h1 class="text-5xl font-bold">Edit a project</h1>
                  <p class="py-5 text-lg">Show your expertise and enhance our works!</p>
                </div>
              </div>
            </div>


            <!-- Form -->
            <form action="/solutions/editProject" method="post">

                <!--Keep track of the project's ID for later data updation-->
                <input type="hidden" name="id" value="<%= project.id %>">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                        <div class="">
                            <label for="title" class="block font-medium my-2">Title</label>
                            <input type="text" id="title" name="title" value="<%= project.title %>" required="" class="input w-full">
                        </div>
                        <div class="">
                            <label for="feature_img_url" class="block font-medium my-2">Feature Image (URL)</label>
                            <input type="url" id="feature_img_url" name="feature_img_url" value="<%= project.feature_img_url %>" required="" class="input w-full">
                        </div>

                        <div class="">
                            <label for="sector_id" class="block font-medium my-2">Sector</label>
                            <select id="sector_id" name="sector_id" required="" class="select w-full">
                                <option value="1" <%= (project.sector_id == 1) ? "selected" : "" %>>Land Sinks</option>
                                <option value="2" <%= (project.sector_id == 2) ? "selected" : "" %>>Industry</option>
                                <option value="3" <%= (project.sector_id == 3) ? "selected" : "" %>>Transportation</option>
                                <option value="4" <%= (project.sector_id == 4) ? "selected" : "" %>>Electricity</option>
                                <option value="5" <%= (project.sector_id == 5) ? "selected" : "" %>>Food, Agriculture, and Land Use</option>
                            </select>
                        </div>


                        <div class="">
                            <label for="intro_short" class="block font-medium my-2">Intro</label>
                            <textarea id="intro_short" name="intro_short" value="<%= project.intro_short %>" required="" class="w-full textarea h-40"></textarea>
                        </div>

                        <div class="">
                            <label for="summary_short" class="block font-medium my-2">Summary</label>
                            <textarea id="summary_short" name="summary_short" value="<%= project.summary_short %>" required="" class="w-full textarea h-40"></textarea>
                        </div>

                        <div class="">
                            <label for="impact" class="block font-medium my-2">Impact</label>
                            <textarea id="impact" name="impact" value="<%= project.impact %>" required="" class="w-full textarea h-40"></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="original_source_url" class="block font-medium my-2">Original Source
                                (URL)</label>
                            <input type="url" id="original_source_url" name="original_source_url" value="<%= project.original_source_url %>" required="" class="w-full input">
                        </div>

                    </div>

                    <div class="mt-3 flex justify-center">
                        <button type="submit" class="btn btn-primary px-10 text-md font-medium">Update Project</button>
                    </div>
                
            </form>

        </div>
    </body>
</html>