<!DOCTYPE html>
<html lang="en" data-theme="luxury">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Login</title>
        <link rel="stylesheet" href="/css/main.css" />
    </head>
    <body>

        <!-- Navbar -->
        <%- include('partials/navbar') %>

        <div class="page-container border-y-0">

            <!-- Header -->
            <div class="standard-hero p-1 mb-3">
              <div class="hero-content text-center ">
                <div class="max-w-md">
                  <h1 class="text-5xl font-bold">Login</h1>
                  <p class="py-5 text-lg">Please enter your username and password below.</p>
                </div>
              </div>
            </div>

            <!-- Form -->
            <form action="/login" method="post" class="mt-8">
                <div class="flex flex-col items-center">
                    <div class="w-full max-w-md mb-4">
                        <label for="username" class="block text-xl font-bold mb-2">Username</label>
                        <input type="text" id="username" name="userName" value="<%= userName %>" placeholder="User Name" required class="input input-bordered input-md w-full text-lg shadow-sm">
                    </div>
                    <div class="w-full max-w-md mb-6">
                        <label for="pw" class="block text-xl font-bold mb-2">Password</label>
                        <input type="password" id="pw" name="password" placeholder="Password" required class="input input-bordered input-md w-full text-lg shadow-sm">
                    </div>
                    <div class="w-full max-w-md flex justify-center">
                        <button type="submit" class="btn btn-primary btn-md max-w-3xs text-xl shadow-md">LOGIN</button>
                    </div>
                </div>
            </form>

            <% if(errorMessage) { %>
                <div role="alert" class="alert alert-error mt-7 max-w-md mx-auto shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="font-semibold"><%= errorMessage %></span> 
                </div>
            <% } %>
            

        </div>
    </body>
</html>